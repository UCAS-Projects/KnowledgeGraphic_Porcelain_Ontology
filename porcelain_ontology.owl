<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.example.org/porcelain"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:por="http://www.example.org/porcelain#">
    
    <owl:Ontology rdf:about="http://www.example.org/porcelain">
        <rdfs:comment>Ceramics and Porcelain Ontology Knowledge Base</rdfs:comment>
    </owl:Ontology>

    <!-- Classes -->
    <owl:Class rdf:about="#Porcelain">
        <rdfs:label xml:lang="zh">瓷器</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#Dynasty">
        <rdfs:label xml:lang="zh">朝代</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#Kiln">
        <rdfs:label xml:lang="zh">窑口</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#GlazeColor">
        <rdfs:label xml:lang="zh">釉色</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#Shape">
        <rdfs:label xml:lang="zh">器型</rdfs:label>
    </owl:Class>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="#hasDynasty">
        <rdfs:domain rdf:resource="#Porcelain"/>
        <rdfs:range rdf:resource="#Dynasty"/>
        <rdfs:label xml:lang="zh">所属朝代</rdfs:label>
    </owl:ObjectProperty>
    
    <owl:ObjectProperty rdf:about="#hasKiln">
        <rdfs:domain rdf:resource="#Porcelain"/>
        <rdfs:range rdf:resource="#Kiln"/>
        <rdfs:label xml:lang="zh">所属窑口</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasGlaze">
        <rdfs:domain rdf:resource="#Porcelain"/>
        <rdfs:range rdf:resource="#GlazeColor"/>
        <rdfs:label xml:lang="zh">釉色类型</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasShape">
        <rdfs:domain rdf:resource="#Porcelain"/>
        <rdfs:range rdf:resource="#Shape"/>
        <rdfs:label xml:lang="zh">器型分类</rdfs:label>
    </owl:ObjectProperty>

    <!-- Data Properties -->
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#Porcelain"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">名称</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#hasDescription">
        <rdfs:domain rdf:resource="#Porcelain"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">描述</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Individuals (Dataset integration) -->
    
    <!-- Dynasties -->
    <owl:NamedIndividual rdf:about="#SongDynasty">
        <rdf:type rdf:resource="#Dynasty"/>
        <rdfs:label xml:lang="zh">宋代</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#YuanDynasty">
        <rdf:type rdf:resource="#Dynasty"/>
        <rdfs:label xml:lang="zh">元代</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#MingDynasty">
        <rdf:type rdf:resource="#Dynasty"/>
        <rdfs:label xml:lang="zh">明代</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#QingDynasty">
        <rdf:type rdf:resource="#Dynasty"/>
        <rdfs:label xml:lang="zh">清代</rdfs:label>
    </owl:NamedIndividual>

    <!-- Kilns -->
    <owl:NamedIndividual rdf:about="#RuKiln">
        <rdf:type rdf:resource="#Kiln"/>
        <rdfs:label xml:lang="zh">汝窑</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#JingdezhenKiln">
        <rdf:type rdf:resource="#Kiln"/>
        <rdfs:label xml:lang="zh">景德镇窑</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#JianKiln">
        <rdf:type rdf:resource="#Kiln"/>
        <rdfs:label xml:lang="zh">建窑</rdfs:label>
    </owl:NamedIndividual>

    <!-- Glazes -->
    <owl:NamedIndividual rdf:about="#CeladonGlaze">
        <rdf:type rdf:resource="#GlazeColor"/>
        <rdfs:label xml:lang="zh">青釉</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#BlueAndWhiteGlaze">
        <rdf:type rdf:resource="#GlazeColor"/>
        <rdfs:label xml:lang="zh">青花</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#DoucaiGlaze">
        <rdf:type rdf:resource="#GlazeColor"/>
        <rdfs:label xml:lang="zh">斗彩</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#FamilleRoseGlaze">
        <rdf:type rdf:resource="#GlazeColor"/>
        <rdfs:label xml:lang="zh">粉彩</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#BlackGlaze">
        <rdf:type rdf:resource="#GlazeColor"/>
        <rdfs:label xml:lang="zh">黑釉</rdfs:label>
    </owl:NamedIndividual>

    <!-- Shapes -->
    <owl:NamedIndividual rdf:about="#BrushWasher">
        <rdf:type rdf:resource="#Shape"/>
        <rdfs:label xml:lang="zh">洗</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Jar">
        <rdf:type rdf:resource="#Shape"/>
        <rdfs:label xml:lang="zh">罐</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Cup">
        <rdf:type rdf:resource="#Shape"/>
        <rdfs:label xml:lang="zh">杯</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Vase_Zun">
        <rdf:type rdf:resource="#Shape"/>
        <rdfs:label xml:lang="zh">尊</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#TeaBowl">
        <rdf:type rdf:resource="#Shape"/>
        <rdfs:label xml:lang="zh">盏</rdfs:label>
    </owl:NamedIndividual>

    <!-- Porcelains -->
    <!-- P001 -->
    <owl:NamedIndividual rdf:about="#P001">
        <rdf:type rdf:resource="#Porcelain"/>
        <por:hasDynasty rdf:resource="#SongDynasty"/>
        <por:hasKiln rdf:resource="#RuKiln"/>
        <por:hasGlaze rdf:resource="#CeladonGlaze"/>
        <por:hasShape rdf:resource="#BrushWasher"/>
        <por:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">北宋汝窑天青釉洗</por:hasName>
        <por:hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">天青釉洗，造型古朴，釉色莹润如玉。</por:hasDescription>
    </owl:NamedIndividual>

    <!-- P002 -->
    <owl:NamedIndividual rdf:about="#P002">
        <rdf:type rdf:resource="#Porcelain"/>
        <por:hasDynasty rdf:resource="#YuanDynasty"/>
        <por:hasKiln rdf:resource="#JingdezhenKiln"/>
        <por:hasGlaze rdf:resource="#BlueAndWhiteGlaze"/>
        <por:hasShape rdf:resource="#Jar"/>
        <por:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">元青花鬼谷子下山图罐</por:hasName>
        <por:hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">著名元青花瓷器，绘有鬼谷子下山故事图案。</por:hasDescription>
    </owl:NamedIndividual>

    <!-- P003 -->
    <owl:NamedIndividual rdf:about="#P003">
        <rdf:type rdf:resource="#Porcelain"/>
        <por:hasDynasty rdf:resource="#MingDynasty"/>
        <por:hasKiln rdf:resource="#JingdezhenKiln"/>
        <por:hasGlaze rdf:resource="#DoucaiGlaze"/>
        <por:hasShape rdf:resource="#Cup"/>
        <por:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">明成化斗彩鸡缸杯</por:hasName>
        <por:hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">价值连城的成化斗彩御用酒杯。</por:hasDescription>
    </owl:NamedIndividual>

    <!-- P004 -->
    <owl:NamedIndividual rdf:about="#P004">
        <rdf:type rdf:resource="#Porcelain"/>
        <por:hasDynasty rdf:resource="#QingDynasty"/>
        <por:hasKiln rdf:resource="#JingdezhenKiln"/>
        <por:hasGlaze rdf:resource="#FamilleRoseGlaze"/>
        <por:hasShape rdf:resource="#Vase_Zun"/>
        <por:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">清乾隆粉彩百鹿尊</por:hasName>
        <por:hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">宫廷御用陈设瓷，绘有百鹿图，寓意百禄。</por:hasDescription>
    </owl:NamedIndividual>

    <!-- P005 -->
    <owl:NamedIndividual rdf:about="#P005">
        <rdf:type rdf:resource="#Porcelain"/>
        <por:hasDynasty rdf:resource="#SongDynasty"/>
        <por:hasKiln rdf:resource="#JianKiln"/>
        <por:hasGlaze rdf:resource="#BlackGlaze"/>
        <por:hasShape rdf:resource="#TeaBowl"/>
        <por:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">宋代建窑黑釉兔毫盏</por:hasName>
        <por:hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">斗茶用具，黑釉表面呈现兔毫状纹理。</por:hasDescription>
    </owl:NamedIndividual>
    
</rdf:RDF>
